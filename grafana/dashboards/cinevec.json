{
  "uid": "cinevec-monitoring",
  "title": "CineVec Monitoring",
  "tags": [
    "cinevec"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "editable": false,
  "panels": [
    {
      "type": "stat",
      "title": "Questions asked",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS \"Questions\"\nFROM conversations\nWHERE $__timeFilter(timestamp);"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Total cost (USD)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(sum(cost), 0) AS \"Cost\"\nFROM conversations\nWHERE $__timeFilter(timestamp);"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "type": "stat",
      "title": "Avg response time",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(avg(response_time), 0) AS \"Avg response time\"\nFROM conversations\nWHERE $__timeFilter(timestamp);"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "type": "piechart",
      "title": "Feedback",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  sum(CASE WHEN score > 0 THEN 1 ELSE 0 END) AS \"Thumbs up\",\n  sum(CASE WHEN score < 0 THEN 1 ELSE 0 END) AS \"Thumbs down\"\nFROM feedback\nWHERE $__timeFilter(timestamp);"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        },
        "pieType": "pie",
        "displayLabels": [
          "percent"
        ],
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "showLegend": true
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Tokens over time",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(timestamp, $__interval),\n  sum(input_tokens)  AS \"Input tokens\",\n  sum(output_tokens) AS \"Output tokens\"\nFROM conversations\nWHERE $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Cost over time",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(timestamp, $__interval),\n  sum(cost) AS \"Cost\"\nFROM conversations\nWHERE $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "auto"
          },
          "unit": "currencyUSD",
          "decimals": 5
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Response time over time",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(timestamp, $__interval),\n  avg(response_time) AS \"Avg\",\n  max(response_time) AS \"Max\"\nFROM conversations\nWHERE $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "auto"
          },
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "type": "barchart",
      "title": "Tool / search mode used",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  t.tool   AS \"Tool\",\n  count(*) AS \"Calls\"\nFROM conversations c, unnest(c.tools_used) AS t(tool)\nWHERE $__timeFilter(c.timestamp)\nGROUP BY 1\nORDER BY 2 DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        }
      }
    },
    {
      "type": "barchart",
      "title": "Model used",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT model AS \"Model\", count(*) AS \"Requests\"\nFROM conversations\nWHERE $__timeFilter(timestamp)\nGROUP BY 1\nORDER BY 2 DESC;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "legend": {
          "showLegend": false
        }
      }
    },
    {
      "type": "table",
      "title": "Recent conversations",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "cinevec-postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "cinevec-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  c.timestamp                          AS \"Time\",\n  c.question                           AS \"Question\",\n  left(c.answer, 200)                  AS \"Answer\",\n  array_to_string(c.tools_used, ', ')  AS \"Tools\",\n  c.input_tokens                       AS \"In\",\n  c.output_tokens                      AS \"Out\",\n  round(c.response_time::numeric, 2)   AS \"Seconds\",\n  round(c.cost::numeric, 5)            AS \"Cost\",\n  CASE WHEN f.score > 0 THEN 'up'\n       WHEN f.score < 0 THEN 'down'\n       ELSE '' END                     AS \"Feedback\"\nFROM conversations c\nLEFT JOIN feedback f ON f.conversation_id = c.id\nWHERE $__timeFilter(c.timestamp)\nORDER BY c.timestamp DESC\nLIMIT 20;"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    }
  ]
}
